{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "**/*.{js,cjs,mjs,jsx,ts,tsx,json,jsonc}",
      "!node_modules",
      "!.venv",
      "!venv",
      "!coverage.xml",
      "!package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  }
}
